# PostgreSQL (with pgvector extension)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5434/rag_db

# LLM Provider: "openai" or "gemini"
LLM_PROVIDER=openai

# OpenAI (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Gemini (required when LLM_PROVIDER=gemini)
GEMINI_API_KEY=

# Optional: override default models per provider
# OpenAI defaults:  chat_model=gpt-4o-mini, embedding_model=text-embedding-3-small
# Gemini defaults:  chat_model=gemini-2.0-flash, embedding_model=text-embedding-004
# CHAT_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536  # OpenAI=1536, Gemini=768

# Application
APP_ENV=development
LOG_LEVEL=INFO
# ALLOWED_ORIGINS=["http://localhost:3000"]
